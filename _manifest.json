{
  "manifest_version": 2,
  "id": "com.0-hz.plastic-memory",
  "version": "0.3.2",
  "name": "塑料内存条 (Plastic Memory)",
  "description": "为麦麦提供自我演化接口（全局 my_memory.md 与按聊天流隔离的 chat_notes），在 planner / 时机判断 / replyer 请求中注入演化指令与剩余空间；麦麦可通过工具向接口写入演化指令，实现写入即自我演化。",
  "author": {
    "name": "kes",
    "url": "https://github.com/yufei-pan"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/yufei-pan/MaiBot-plastic-memory-plugin",
    "homepage": "https://github.com/yufei-pan/MaiBot-plastic-memory-plugin",
    "documentation": "https://github.com/yufei-pan/MaiBot-plastic-memory-plugin/blob/main/README.md",
    "issues": "https://github.com/yufei-pan/MaiBot-plastic-memory-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "config.get",
    "llm.generate"
  ],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
